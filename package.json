{
  "name": "react-vscode-shell",
  "version": "1.0.0",
  "description": "React + TypeScript VSCode-style IDE shell — browser and Electron",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev":              "vite --port 5174 --strictPort",
    "build":            "tsc -b && vite build",
    "preview":          "vite preview",
    "electron:dev":     "concurrently \"npm run dev\" \"wait-on http://localhost:5174 && electron . --dev\"",
    "electron:build":   "npm run build && electron-builder",
    "lint":             "eslint ."
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.487.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "electron": "^32.3.3",
    "electron-builder": "^24.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^8.0.12",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.kalpanavigyaan.react-vscode-shell",
    "productName": "React VSCode Shell",
    "directories": { "output": "dist-electron" },
    "files": [
      "electron/**/*",
      "dist/**/*"
    ],
    "extraResources": [],
    "win": {
      "target": "portable"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
